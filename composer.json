{
    "name": "moselwal/typo3-config",
    "description": "Fluent API to set environment-specific configuration for TYPO3.",
    "license": "MIT",
    "keywords": ["typo3", "configuration", "environment", "dotenv", "12factor"],
    "authors": [
        {
            "name": "Moselwal Digitalagentur GmbH",
            "email": "support@moselwal.io",
            "homepage": "https://moselwal.io",
            "role": "Maintainer"
        },
        {
            "name": "Kai Ole Hartwig",
            "email": "o.hartwig@moselwal.de",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/Moselwal-Digitalagentur/typo3-config/issues",
        "source": "https://github.com/Moselwal-Digitalagentur/typo3-config"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://gitlab.moselwal.io/api/v4/group/175/-/packages/composer/packages.json"
        }
    ],
    "require": {
        "php": "^8.5",
        "composer/installers": "^2.3",
        "typo3/cms-core": "^14.0"
    },
    "require-dev": {
        "moselwal/dev": "^5.0",
        "php-mock/php-mock-phpunit": "^2.10"
    },
    "autoload": {
        "psr-4": {
            "Moselwal\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moselwal\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "phpstan": "phpstan analyse"
    },
    "suggest": {
        "moselwal/keyvalue-store": "Redis/Valkey integration for caching, sessions, and locking"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true,
            "phpstan/extension-installer": true,
            "sbuerk/typo3-cmscomposerinstallers-testingframework-bridge": true
        }
    }
}

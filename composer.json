{
	"name": "moselwal/typo3-config",
	"description": "Fluent API to set environment-specific configuration for TYPO3",
	"license": "MIT",
	"require": {
		"php": "^8.2",
		"composer/installers": "^2.3",
		"typo3/cms-core": "^14.0"
	},
	"autoload": {
		"psr-4": {
			"Moselwal\\": "src"
		}
	},
	"require-dev": {
		"moselwal/dev": "*",
		"phpunit/phpunit": "^9.6",
		"php-mock/php-mock-phpunit": "^2.10",
		"phpstan/phpstan": "^2.1"
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-text",
		"phpstan": "phpstan analyse"
	},
	"suggest": {
		"moselwal/keyvalue-store": "*"
	},
	"config": {
		"allow-plugins": {
			"typo3/cms-composer-installers": true,
			"typo3/class-alias-loader": true
		}
	}
}

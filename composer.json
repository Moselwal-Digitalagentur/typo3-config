{
	"name": "moselwal/typo3-config",
	"description": "Fluent API to set environment-specific configuration for TYPO3",
	"license": "MIT",
	"require": {
		"php": "^8.5",
		"composer/installers": "^2.3",
		"typo3/cms-core": "^14.0"
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://gitlab.moselwal.io/api/v4/group/175/-/packages/composer/packages.json"
		}
	],
	"autoload": {
		"psr-4": {
			"Moselwal\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Moselwal\\Tests\\": "tests"
		}
	},
	"require-dev": {
		"moselwal/dev": "^5.0",
		"php-mock/php-mock-phpunit": "^2.10"
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-text",
		"phpstan": "phpstan analyse"
	},
	"suggest": {
		"moselwal/keyvalue-store": "Redis/Valkey integration for caching, sessions, and locking"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"typo3/cms-composer-installers": true,
			"typo3/class-alias-loader": true,
			"phpstan/extension-installer": true,
			"sbuerk/typo3-cmscomposerinstallers-testingframework-bridge": true
		}
	}
}
